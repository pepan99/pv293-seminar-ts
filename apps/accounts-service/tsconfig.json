{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@repo/typescript-config/nestjs.json",
  "include": [
    "src/**/*",
    "test/**/*",
    "scripts/**/*"
  ],
  "exclude": [
    "src/modules/users/repositories/in-memory-users.repository.ts"
  ],
  "compilerOptions": {
    "moduleResolution": "node",
    "typeRoots": [
      "./node_modules/@types/",
      "./src/common/types/express.d.ts",
      "./src/common/types/k6-utils.d.ts",
    ],
    "outDir": "./dist"
  }
}
